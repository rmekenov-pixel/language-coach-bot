# Скопируй этот файл в .env и заполни реальными значениями из Meta for Developers.
# .env НИКОГДА не должен попасть в git (он уже в .gitignore).

# Токен доступа Graph API (временный из Meta for Developers, либо постоянный System User token)
WHATSAPP_TOKEN=your_token_here

# ID тестового номера WhatsApp (находится в Meta for Developers -> WhatsApp -> API Setup)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Произвольная строка, которую ты сам придумываешь и указываешь
# в настройках вебхука в Meta for Developers (поле Verify Token)
WHATSAPP_VERIFY_TOKEN=choose_any_secret_string_here
